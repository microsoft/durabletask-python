FROM python:3.12-slim AS runtime

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
ENV GRPC_DEFAULT_SSL_ROOTS_FILE_PATH=/etc/ssl/certs/ca-certificates.crt

COPY . /src
RUN pip install --no-cache-dir /src /src/durabletask-azuremanaged azure-identity

COPY examples/sandboxes/remote_worker.py /app/remote_worker.py
COPY examples/sandboxes/activities.py /app/activities.py

ENTRYPOINT ["python", "/app/remote_worker.py"]
